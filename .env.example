APP_NAME=SafeSphere AI Backend
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2
API_PREFIX=/api
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=safesphere
JWT_SECRET_KEY=replace-with-very-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=https://your-frontend-domain.com
TRUSTED_HOSTS=your-api-domain.com,localhost,127.0.0.1
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_LOG_LEVEL=info

